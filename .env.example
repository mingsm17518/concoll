# API Provider: "openai" or "anthropic"
API_PROVIDER=openai

# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Configuration (for GLM/MiniMax)
ANTHROPIC_AUTH_TOKEN=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Model Configuration
MODEL=gpt-4o
ANTHROPIC_MODEL=MiniMax-M2.1

# ConColl Parameters
# Stage 1 confidence threshold (0.0-1.0, default: 0.3)
# Higher = more samples go to Stage 2/3 for detailed analysis
# Lower = more samples accepted in Stage 1
# CONFIDENCE_THRESHOLD=0.3
